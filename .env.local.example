# ---- Supabase (required for Phase 1) ----
# Project URL: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only. Needed for admin operations in server actions.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Claude API (required for Phase 2: document extraction) ----
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ---- Email ingest (Phase 3) ----
POSTMARK_INBOUND_SECRET=generate-a-random-string

# ---- Digest emails (Phase 4) ----
RESEND_API_KEY=re_...
